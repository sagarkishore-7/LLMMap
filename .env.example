# ===========================================================================
# LLMMap + PromptLab — Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your values.
# All variables have sensible defaults for local development with Ollama Cloud.

# ---------------------------------------------------------------------------
# Ollama Cloud (default LLM backend for both local and production)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_MODEL=qwen3-coder-next:cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key-here

# To use local Ollama instead (advanced):
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=dolphin3:8b
# OLLAMA_API_KEY=            # not needed for local

# ---------------------------------------------------------------------------
# Alternative LLM providers (for LLMMap CLI only)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# ---------------------------------------------------------------------------
# PromptLab Backend
# ---------------------------------------------------------------------------
# PORT is set automatically by Railway. For local dev, defaults to 8000.
# PORT=8000

# CORS origins — comma-separated. Defaults to localhost:3000 for local dev.
# Set to your Vercel URL in production.
# PROMPTLAB_CORS_ORIGINS=https://your-app.vercel.app

# ---------------------------------------------------------------------------
# PromptLab Frontend (set in Vercel project settings)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL=https://your-api.railway.app
